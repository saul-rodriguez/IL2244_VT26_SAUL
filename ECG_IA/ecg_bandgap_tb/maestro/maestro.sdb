		<tests>
			<test enabled="1">DC
				<tool>ADE</tool>
				<tooloptions>
					<option>cell
						<value>ecg_bandgap_tb</value>
					</option>
					<option>lib
						<value>ECG_IA</value>
					</option>
					<option>sim
						<value>spectre</value>
					</option>
					<option>view
						<value>schematic</value>
					</option>
					<option>path
						<value>$AXL_SETUPDB_DIR</value>
					</option>
					<option>state
						<value>active</value>
					</option>
				</tooloptions>
				<vars>
					<var>VDD
						<value>3.3</value>
					</var>
					<var>VDD_PULSE
						<value>0</value>
					</var>
					<var>VDD_RISE
						<value>1u</value>
					</var>
				</vars>
				<outputs>
					<output>VDC("/BG_REF")
						<evalType>point</evalType>
					</output>
					<output>Output_noise_Vrms
						<evalType>point</evalType>
					</output>
					<output>Output_noise_ECG_Vrms
						<units></units>
						<significantDigits>0</significantDigits>
						<notation></notation>
						<suffix></suffix>
						<evalType>point</evalType>
					</output>
				</outputs>
			</test>
			<test enabled="1">DC_MC
