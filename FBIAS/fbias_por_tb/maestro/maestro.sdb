				<currentmode>Single Run, Sweeps and Corners</currentmode>
				<overwritehistory>0</overwritehistory>
				<tests>
					<test enabled="1">DC
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>fbias_por_tb</value>
							</option>
							<option>lib
								<value>FBIAS</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Interactive.59</value>
							</option>
						</tooloptions>
						<vars>
							<var>VDD_STEP
								<value>0</value>
							</var>
							<var>VDD_TR
								<value>1u</value>
							</var>
							<var>VDD
								<value>3.3</value>
							</var>
							<var>VDD_BOR
								<value>0</value>
							</var>
						</vars>
						<outputs>
							<output>VDC("/VBG")
								<evalType>point</evalType>
							</output>
							<output>IDC("/I2/BIAS")
								<evalType>point</evalType>
							</output>
							<output>IDC("/I0/BIAS")
								<units></units>
								<significantDigits>0</significantDigits>
								<notation></notation>
								<suffix></suffix>
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
					<test enabled="1">TRAN
						<tool>ADE</tool>
						<vars>
							<var>VDD_STEP
								<value>3.3</value>
							</var>
							<var>VDD_TR
								<value>1u</value>
							</var>
							<var>VDD
								<value>0</value>
							</var>
							<var>VDD_BOR
								<value>-350m</value>
							</var>
						</vars>
						<tooloptions>
							<option>cell
								<value>fbias_por_tb</value>
							</option>
							<option>lib
								<value>FBIAS</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Interactive.59</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
						</tooloptions>
						<prerunscript>0</prerunscript>
						<outputs>
							<output>/POR_L
								<evalType>point</evalType>
							</output>
							<output>/VBG
								<evalType>point</evalType>
							</output>
							<output>/VDD
								<evalType>point</evalType>
							</output>
							<output>/IPRB0/MINUS
								<evalType>point</evalType>
							</output>
							<output>/I0/VY
								<evalType>point</evalType>
							</output>
							<output>BIAS_BG
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
