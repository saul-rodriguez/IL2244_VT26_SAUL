				<tests>
					<test enabled="1">DC
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>fbias_por_tb</value>
							</option>
							<option>lib
								<value>FBIAS</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Interactive.55</value>
							</option>
						</tooloptions>
						<vars>
							<var>VDD_STEP
								<value>0</value>
							</var>
							<var>VDD_TR
								<value>1u</value>
							</var>
							<var>VDD
								<value>3.3</value>
							</var>
							<var>VDD_BOR
								<value>0</value>
							</var>
						</vars>
						<outputs>
							<output>VDC("/VBG")
								<evalType>point</evalType>
							</output>
							<output>IDC("/I2/BIAS")
								<evalType>point</evalType>
							</output>
							<output>IDC("/I0/BIAS")
								<units></units>
