				<overwritehistory>0</overwritehistory>
				<tests>
					<test enabled="1">DC
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>fecg_bandgap_tb</value>
							</option>
							<option>lib
								<value>FECG</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Interactive.26</value>
							</option>
						</tooloptions>
						<vars>
							<var>VDD
								<value>3.3</value>
							</var>
							<var>VDD_PULSE
								<value>0</value>
							</var>
							<var>VDD_RISE
								<value>1u</value>
							</var>
						</vars>
						<outputs>
							<output>VDC("/BG_REF")
								<evalType>point</evalType>
							</output>
							<output>Output_noise_Vrms
								<evalType>point</evalType>
							</output>
							<output>Output_noise_ECG_Vrms
								<units></units>
								<significantDigits>0</significantDigits>
								<notation></notation>
								<suffix></suffix>
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
