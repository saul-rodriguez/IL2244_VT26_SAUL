					<test netlist="0" netlistscope="all">FBIAS_fbias_bias_tb_1</test>
					<test netlist="0" netlistscope="all">DC</test>
					<test netlist="0" netlistscope="all">DC_MC</test>
					<test netlist="0" netlistscope="all">TRAN</test>
				</checksasserts>
