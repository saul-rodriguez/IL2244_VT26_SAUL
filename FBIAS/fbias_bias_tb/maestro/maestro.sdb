								<suffix></suffix>
								<evalType>point</evalType>
							</output>
							<output>PSRR_1Hz
								<evalType>point</evalType>
							</output>
							<output>IBIAS
								<evalType>point</evalType>
							</output>
						</outputs>
						<vars>
							<var>VDD
								<value>3.3</value>
							</var>
							<var>VDD_PULSE
								<value>0</value>
							</var>
							<var>VDD_TR
								<value>1u</value>
							</var>
