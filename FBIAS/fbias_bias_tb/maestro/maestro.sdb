				<tests>
					<test enabled="1">DC
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>fbias_bias_tb</value>
							</option>
							<option>lib
								<value>FBIAS</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Interactive.11</value>
							</option>
						</tooloptions>
						<vars>
							<var>VDD
								<value>3.3</value>
							</var>
							<var>VDD_PULSE
								<value>0</value>
							</var>
							<var>VDD_TR
								<value>1u</value>
							</var>
						</vars>
						<outputs>
							<output>V1600
								<evalType>point</evalType>
							</output>
							<output>Vnoise_rms_100MHz
								<evalType>point</evalType>
							</output>
							<output>Vnoise_rms_200Hz
								<units></units>
								<significantDigits>0</significantDigits>
								<notation></notation>
								<suffix></suffix>
								<evalType>point</evalType>
							</output>
							<output>PSRR_1Hz
								<evalType>point</evalType>
							</output>
							<output>IBIAS
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
